package library_db;

import java.sql.*;
public class Login {

    public static String validate(String username, String password) {
        try {
            Connection con = DBConnection.getConnection();
            String sql = "SELECT id, role, username FROM users WHERE username=? AND password=?";
            PreparedStatement ps = con.prepareStatement(sql);
            ps.setString(1, username);
            ps.setString(2, password);

            ResultSet rs = ps.executeQuery();

            if (rs.next()) {
                Session.loggedInUserId = rs.getInt("id");
                Session.loggedInUsername = rs.getString("username");
                Session.loggedInRole = rs.getString("role");
                return rs.getString("role");  // return role
            }

        } catch (Exception e) {
            e.printStackTrace();
        }
        return null;   // login failed
    }
}


