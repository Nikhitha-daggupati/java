package library_db;

import javax.swing.*;
import java.awt.*;
import java.sql.Connection;
import java.sql.PreparedStatement;
import java.sql.ResultSet;

public class ChangePasswordUI extends JFrame {

    public ChangePasswordUI() {

        setTitle("Change Password");
        setSize(350, 200);
        setLocationRelativeTo(null);
        setLayout(new GridLayout(4, 2, 10, 10));

        JLabel oldPassLabel = new JLabel("Old Password:");
        JPasswordField oldPassField = new JPasswordField();

        JLabel newPassLabel = new JLabel("New Password:");
        JPasswordField newPassField = new JPasswordField();

        JButton checkBtn = new JButton("Change");

        add(oldPassLabel);
        add(oldPassField);
        add(newPassLabel);
        add(newPassField);
        add(new JLabel());
        add(checkBtn);

        checkBtn.addActionListener(e -> {
            String oldPass = new String(oldPassField.getPassword());
            String newPass = new String(newPassField.getPassword());

            if (newPass.isEmpty()) {
                JOptionPane.showMessageDialog(this, "New password cannot be empty!");
                return;
            }

            try {
                Connection con = DBConnection.getConnection();
                
                String sql = "SELECT id FROM users WHERE id=? AND password=?";
                PreparedStatement ps = con.prepareStatement(sql);
                ps.setInt(1, Session.loggedInUserId);
                ps.setString(2, oldPass);

                ResultSet rs = ps.executeQuery();
                if (rs.next()) {
                    String updateSql = "UPDATE users SET password=? WHERE id=?";
                    PreparedStatement updatePs = con.prepareStatement(updateSql);
                    updatePs.setString(1, newPass);
                    updatePs.setInt(2, Session.loggedInUserId);
                    updatePs.executeUpdate();

                    JOptionPane.showMessageDialog(this, "Password changed successfully!");
                    dispose();
                } else {
                    JOptionPane.showMessageDialog(this, "Incorrect old password!");
                }
                con.close();
            } catch (Exception ex) {
                ex.printStackTrace();
            }
        });

        setVisible(true);
    }
}
