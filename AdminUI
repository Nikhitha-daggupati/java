package library_db;

import javax.swing.*;
import java.awt.*;
import java.awt.event.ActionEvent;
import java.awt.event.ActionListener;

public class AdminUI extends JFrame {

    public AdminUI() {

        setTitle("Admin Dashboard");
        setSize(400, 550);
        setLocationRelativeTo(null);
        setLayout(new GridLayout(7, 1, 10, 10));

        JLabel title = new JLabel("Admin Menu", JLabel.CENTER);
        title.setFont(new Font("Arial", Font.BOLD, 18));

        JButton viewBooksBtn = new JButton("View Books");
        JButton viewStudentsBtn = new JButton("View Students");
        JButton viewFacultyBtn = new JButton("View Faculty");
        JButton checkFineBtn = new JButton("Check Fine");
        JButton processNotificationsBtn = new JButton("Process Notifications");
        JButton logoutBtn = new JButton("Logout");

        add(title);
        add(viewBooksBtn);
        add(viewStudentsBtn);
        add(viewFacultyBtn);
        add(checkFineBtn);
        add(processNotificationsBtn);
        add(logoutBtn);

        // 🔥 Button Actions
        viewBooksBtn.addActionListener(e -> new ViewBooksUI());

        viewStudentsBtn.addActionListener(e -> new ViewUsersUI("student"));

        viewFacultyBtn.addActionListener(e -> new ViewUsersUI("faculty"));

        checkFineBtn.addActionListener(e -> new CheckFineUI());

        processNotificationsBtn.addActionListener(e -> 
                FineNotificationService.processDailyNotifications()
        );

        logoutBtn.addActionListener(e -> {
            dispose();
            new LoginUI();
        });

        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setVisible(true);
    }
}
